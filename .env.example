# EmailJS Configuration - REQUIRED for contact form to work
# Get these values from your EmailJS account at https://www.emailjs.com

# Your EmailJS Public Key (from Account → API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (from Email Services, e.g., Gmail)
VITE_EMAILJS_SERVICE_ID=service_your_service_id

# Your EmailJS Template ID (from Email Templates)
VITE_EMAILJS_TEMPLATE_ID=template_your_template_id

# NOTE: Copy this file to .env.local and fill in your actual values
# Keep .env.local private (it's already in .gitignore)
# The VITE_ prefix makes these variables available to the browser
# The code also supports NEXT_PUBLIC_ prefix for backwards compatibility
