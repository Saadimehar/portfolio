# Formspree Configuration - for contact form
# The contact form uses Formspree (https://formspree.io/) for email submissions
# No environment variables are required - the endpoint is hardcoded in the component
# 
# If you want to change the Formspree endpoint:
# 1. Edit src/components/sections/Contact.tsx
# 2. Update the FORMSPREE_ENDPOINT constant with your form URL
# 
# Example: const FORMSPREE_ENDPOINT = "https://formspree.io/f/YOUR_FORM_ID";

# NOTE: Copy this file to .env.local and keep it private (don't commit to Git)
# .env.local is already in .gitignore for security
